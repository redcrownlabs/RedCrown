{
  "name": "redcrown-desktop",
  "version": "0.2.6",
  "description": "Windows-first watch-now desktop media player",
  "author": "redcrownlabs",
  "license": "MIT",
  "homepage": "https://github.com/redcrownlabs/RedCrown",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "package:win": "electron-builder --win nsis zip --x64",
    "start": "electron .",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "6.0.3",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.4",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.3.0",
    "jsdom": "29.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wait-on": "9.0.4"
  },
  "build": {
    "appId": "io.github.redcrownlabs.redcrown",
    "productName": "RedCrown",
    "asar": true,
    "compression": "normal",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../.redcrown/release-resources",
        "to": ".",
        "filter": ["**/*"]
      }
    ],
    "artifactName": "RedCrown-${version}-windows-${arch}.${ext}",
    "win": {
      "icon": "public/redcrown-mark.svg",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
